; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="시간이 멈춘 숲"
config/version="0.0.1"
run/main_scene="res://src/ui/menus/title/TitleScreen.tscn"
config/features=PackedStringArray("4.6")

[autoload]

EventBus="*res://src/systems/event_bus/event_bus.gd"
StateFlags="*res://src/systems/state_flags/state_flag_persistence.gd"
OverlaySystem="*res://src/systems/overlay/overlay_system.gd"
EffectsSystem="*res://src/systems/effects/effects_system.gd"
GrowthSystem="*res://src/systems/growth/growth_system.gd"
InventorySystem="*res://src/systems/inventory/inventory_system.gd"
TimeSystem="*res://src/systems/time/time_system.gd"
ShadowSystem="*res://src/systems/shadow/shadow_system.gd"
EnemySystem="*res://src/systems/enemy/enemy_system.gd"
CombatSystem="*res://src/systems/combat/combat_system.gd"
StageSystem="*res://src/systems/stage/stage_system.gd"
DuskSpiderSystem="*res://src/systems/dusk_spider/dusk_spider_system.gd"
SkillSystem="*res://src/systems/skill/skill_system.gd"
AbilitySystem="*res://src/systems/ability/ability_system.gd"
WorldMapUI="*res://src/ui/menus/world_map/world_map_ui.gd"
InventoryMenu="*res://src/ui/menus/inventory/inventory_menu.gd"
ShopMenu="*res://src/ui/menus/shop/shop_menu.gd"
PauseMenu="*res://src/ui/menus/pause/pause_menu.gd"
KeybindHud="*res://src/ui/hud/KeybindHud.tscn"
StageNameplate="*res://src/ui/hud/stage_nameplate.gd"
IntroSequence="*res://src/ui/hud/intro_sequence.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/snap_2d_transforms_to_pixel=true
window/snap_2d_vertices_to_pixel=true

[gui]

theme/custom="res://data/themes/main_theme.tres"

